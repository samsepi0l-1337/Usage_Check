{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "UsageCheck",
  "version": "0.1.0",
  "identifier": "com.usagecheck.app",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../ui/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "UsageCheck",
        "width": 360,
        "height": 480,
        "visible": false,
        "resizable": true
      }
    ],
    "trayIcon": {
      "iconPath": "icons/icon.png"
    },
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png"]
  }
}
